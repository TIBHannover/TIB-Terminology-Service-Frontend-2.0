{
  "compilerOptions": {       
    "target": "es2021",
    "jsx": "react-jsx", 
    "module": "commonjs",    
    "allowJs": true,     
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  }
}
